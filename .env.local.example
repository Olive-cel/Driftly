# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# OpenAI (pour la génération d'itinéraires)
OPENAI_API_KEY=sk-proj-your-key-here

# Pexels (pour les images)
PEXELS_API_KEY=your_pexels_key_here

# Amadeus (optionnel - pour les vols)
AMADEUS_CLIENT_ID=your_amadeus_client_id
AMADEUS_CLIENT_SECRET=your_amadeus_client_secret

# Admin/Service (serveur uniquement - NE PAS exposer au client)
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key (optionnel pour admin endpoints)
